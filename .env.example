# DREAM data directory. Each tenant/agent/user remains isolated below this root.
DREAM_HOME=~/.dream

# Background Review: deterministic (offline/testing) or openai.
DREAM_REVIEW_BACKEND=openai
DREAM_REVIEW_MODEL=your-openai-compatible-model
DREAM_REVIEW_BASE_URL=https://api.openai.com/v1
DREAM_LLM_API_KEY=your-secret
DREAM_REVIEW_MAX_COMPLETION_TOKENS=2000

# AI decision-card and user-profile Curators.
# inherit reuses the Background Review provider, model, endpoint, and key.
DREAM_CURATOR_BACKEND=inherit
DREAM_CURATOR_MODEL=
DREAM_CURATOR_BASE_URL=
DREAM_CURATOR_LLM_API_KEY=
DREAM_CURATOR_MAX_COMPLETION_TOKENS=3000

# Optional read-only pull source for completed Internship conversations.
DREAM_INTERNSHIP_SOURCE_ENABLED=false
DREAM_INTERNSHIP_SOURCE_URL=http://127.0.0.1:8000/v1/memory/dream-export
DREAM_INTERNSHIP_SOURCE_API_KEY=
DREAM_INTERNSHIP_SOURCE_TENANT_ID=enterprise-a
DREAM_INTERNSHIP_SOURCE_AGENT_ID=service-agent
DREAM_INTERNSHIP_SOURCE_BATCH_SIZE=100
DREAM_INTERNSHIP_SOURCE_TIMEOUT_SECONDS=15
DREAM_INTERNSHIP_SOURCE_INTERVAL_SECONDS=300
